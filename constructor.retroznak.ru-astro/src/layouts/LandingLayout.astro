---
import BaseLayout from "./BaseLayout.astro";
import { Logo } from "@/components/landing/Logo";
import { Navigation } from "@/components/landing/Navigation";
import { MobileNavDrawer } from "@/components/landing/MobileNavDrawer";
import { ThemeToggle } from "@/components/ThemeToggle";
import { CTAButton } from "@/components/landing/CTAButton";
import { FooterNav } from "@/components/landing/FooterNav";
import { QuestionModal } from "@/components/landing/Forms/QuestionModal";
import { CallbackModal } from "@/components/landing/Forms/CallbackModal";
import { ConsultationModal } from "@/components/landing/Forms/ConsultationModal";
import { navigationContent } from "@/content/navigation";
import { footerContent } from "@/content/footer";
import { asset } from "@/lib/base-path";
import { typograf } from "@/lib/typograf";

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;

const { menuItems, cta, messengers } = navigationContent;
const { menu, legal } = footerContent;

const currentYear = new Date().getFullYear();
const typografLegal = typograf(legal);
const typografFooterDesc = typograf(
  "Объёмные ретрознаки с подсветкой. Восстанавливаем исторические формы и создаём современные решения для домов, бизнеса и музеев."
);
const typografPrivacy = typograf("Политика конфиденциальности");
const typografConsent = typograf("Согласие на обработку ПД");
const typografCopyright = typograf(
  `© 2017–${currentYear} ООО «Три Кита». Все права защищены.`
);
---

<BaseLayout title={title} description={description}>
  <div class="relative flex min-h-screen flex-col bg-background text-foreground">
    <header class="absolute top-0 z-40 w-full">
      <div class="container flex w-full items-center justify-between gap-6 py-5">
        <a
          href="#hero"
          class="inline-flex items-center gap-2 transition-opacity hover:opacity-80"
          aria-label="Retroznak"
        >
          <Logo variant="light" className="h-8 w-auto" />
        </a>
        <Navigation menuItems={menuItems} client:load />
        <div class="flex items-center gap-3">
          <div class="hidden items-center gap-3 lg:flex">
            <a
              href="https://max.ru/u/f9LHodD0cOIEbD_OdC-W2plmBZXw9TBsnOkjLHduOoV7V04iu37eGsdGMmQ"
              target="_blank"
              rel="noreferrer"
              class="group inline-flex h-10 w-10 items-center justify-center rounded-full bg-white/10 dark:bg-white/10 backdrop-blur-sm transition-all duration-200 hover:bg-white hover:scale-110"
              aria-label="MAX"
            >
              <img src={asset("/contacts/max.svg")} alt="MAX" width="20" height="20" class="h-5 w-5 rounded" />
            </a>
            <a
              href="https://t.me/retroznakrf"
              target="_blank"
              rel="noreferrer"
              class="group inline-flex h-10 w-10 items-center justify-center rounded-full bg-white/10 dark:bg-white/10 backdrop-blur-sm transition-all duration-200 hover:bg-white hover:scale-110"
              aria-label="Telegram"
            >
              <svg viewBox="0 0 24 24" class="h-5 w-5 transition-colors group-hover:fill-[#0088cc]" fill="#0088cc">
                <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z" />
              </svg>
            </a>
            <ThemeToggle client:load />
          </div>
          <CTAButton cta={cta} size="sm" className="hidden lg:inline-flex" client:load />
          <div class="flex items-center gap-3 lg:hidden">
            <ThemeToggle client:load />
            <MobileNavDrawer menuItems={menuItems} cta={cta} messengers={messengers} client:load />
          </div>
        </div>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-border bg-secondary/50 py-12">
      <div class="container space-y-10">
        <div class="space-y-6">
          <div>
            <Logo className="h-8 w-auto" />
            <p class="mt-3 max-w-md text-sm text-muted-foreground">{typografFooterDesc}</p>
          </div>
          <FooterNav menu={menu} client:load />
        </div>
        <div class="flex flex-col gap-3 border-t border-border pt-6 text-xs text-muted-foreground sm:flex-row sm:items-center sm:justify-between">
          <p>{typografLegal}</p>
          <div class="flex flex-col items-start gap-1 sm:items-center">
            <a
              href="/privacy"
              target="_blank"
              rel="noopener noreferrer"
              class="underline underline-offset-2 decoration-muted-foreground whitespace-nowrap"
            >
              {typografPrivacy}
            </a>
            <a
              href="/consent"
              target="_blank"
              rel="noopener noreferrer"
              class="underline underline-offset-2 decoration-muted-foreground whitespace-nowrap"
            >
              {typografConsent}
            </a>
          </div>
          <p class="sm:text-right">{typografCopyright}</p>
        </div>
      </div>
    </footer>

    <!-- Модальные окна форм -->
    <QuestionModal client:idle />
    <CallbackModal client:idle />
    <ConsultationModal client:idle />
  </div>
</BaseLayout>
