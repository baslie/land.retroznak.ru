---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Logo } from "@/components/landing/Logo";
import { typograf } from "@/lib/typograf";

const title = typograf("Спасибо за заявку!");
const description = typograf(
  "Мы получили вашу заявку и свяжемся с вами в течение 24 часов в рабочее время. Если вопрос срочный, позвоните нам напрямую."
);
const officeTitle = typograf("Офис Томск");
const emailTitle = typograf("Email");
const scheduleTitle = typograf("Режим работы");
const schedule = typograf("ПН-ПТ: 09:00-18:00, СБ-ВС: выходной");
const homeButton = typograf("На главную");
---

<BaseLayout title={typograf("Спасибо за заявку")} description={typograf("Мы получили вашу заявку и свяжемся с вами в ближайшее время.")} noindex={true}>
  <section class="relative overflow-hidden min-h-screen flex items-center justify-center">
    <video
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      poster="/hero/video-preview.jpg"
      class="pointer-events-none absolute inset-0 z-0 h-full w-full object-cover"
    >
      <source src="/hero/video.webm" type="video/webm" />
      <source src="/hero/video.mp4" type="video/mp4" />
    </video>

    <div class="pointer-events-none absolute inset-0 z-10 bg-black/20 dark:bg-black/20" aria-hidden="true"></div>

    <div class="container relative z-20 flex items-center justify-center py-16">
      <div class="relative max-w-3xl text-center">
        <div class="relative z-10 space-y-8">
          <div class="space-y-4">
            <div class="mx-auto mb-6 flex items-center justify-center">
              <img src="/brand/logo.svg" alt="Ретрознак" width="175" height="44" class="h-auto w-32" />
            </div>
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white text-balance">
              {title}
            </h1>
          </div>

          <p class="text-lg md:text-xl text-white/90 mx-auto text-balance max-w-2xl">
            {description}
          </p>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-4 pt-4">
            <div class="rounded-2xl bg-white/10 backdrop-blur-sm border border-white/20 p-6 space-y-2">
              <div class="flex justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-orange-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
              </div>
              <h3 class="text-white font-semibold">{officeTitle}</h3>
              <a href="tel:+79832322206" class="text-white/90 hover:text-white transition-colors text-sm block">
                +7 (983) 232-22-06
              </a>
            </div>

            <div class="rounded-2xl bg-white/10 backdrop-blur-sm border border-white/20 p-6 space-y-2">
              <div class="flex justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-orange-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
              </div>
              <h3 class="text-white font-semibold">{emailTitle}</h3>
              <a href="mailto:***REMOVED***" class="text-white/90 hover:text-white transition-colors text-sm block">
                ***REMOVED***
              </a>
            </div>

            <div class="rounded-2xl bg-white/10 backdrop-blur-sm border border-white/20 p-6 space-y-2">
              <div class="flex justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-orange-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
              </div>
              <h3 class="text-white font-semibold">{scheduleTitle}</h3>
              <span class="text-white/90 text-sm block">{schedule}</span>
            </div>
          </div>

          <div class="flex justify-center pt-4">
            <a href="/#hero" class="inline-flex items-center gap-2 bg-orange-600 hover:bg-orange-700 text-white shadow-lg px-6 py-3 rounded-lg font-medium transition-colors" style="direction: ltr">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="transform: scaleX(1)"><path d="m12 19-7-7 7-7"></path><path d="M19 12H5"></path></svg>
              <span>{homeButton}</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
